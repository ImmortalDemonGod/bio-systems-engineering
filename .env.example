# Bio-Systems Engineering — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Strava API ──────────────────────────────────────────────────────────────
# Register your app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# Long-lived refresh token obtained from the initial OAuth flow.
# To get one: run `python tools/strava_auth.py` and follow the prompts.
# It does not expire unless revoked.
STRAVA_REFRESH_TOKEN=your_refresh_token_here

# ── HabitDash API ────────────────────────────────────────────────────────────
# Obtain from your HabitDash account settings → API Keys.
# Used by: biosystems wellness-sync, daily_running_brief
HABITDASH_API_KEY=your_habitdash_api_key_here

# ── AI Providers (daily_running_brief only) ──────────────────────────────────
# OpenAI key for the primary synthesis model (gpt-5-mini).
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic key for the operator-context model (optional fallback).
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Biosystems Paths (optional overrides) ────────────────────────────────────
# Directory where wellness.parquet and run history are stored.
# Defaults to ~/.biosystems if not set.
BIOSYSTEMS_HOME=/path/to/your/biosystems/data

# Path to a custom zones YAML file.
# Defaults to data/zones_personal.yml if not set.
BIOSYSTEMS_ZONES_PATH=/path/to/your/zones_personal.yml
